# Fashion Trends MCP Apps bridge configuration

# Port for the Node.js MCP Apps bridge
PORT=8787

# Public base URL used inside widget links and proxied media.
# Set this to your tunnel/domain when exposing the bridge to ChatGPT.
# PUBLIC_BASE_URL=https://your-public-domain.example

# Preferred backend MCP endpoint. The Node bridge talks to the Python server here.
BACKEND_MCP_URL=http://127.0.0.1:8000/mcp

# Canonical CDN base used for fashion media. Legacy S3 image URLs are rewritten here.
MEDIA_CDN_BASE_URL=https://d99zyv0ifyenn.cloudfront.net

# Legacy fallback supported by server.js. If BACKEND_MCP_URL is omitted and API_URL
# is set, /mcp will be appended automatically.
# API_URL=http://127.0.0.1:8000
